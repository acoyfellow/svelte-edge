{
  "name": "svelte-edge",
  "version": "0.0.0",
  "type": "module",
  "private": false,
  "description": "Experiments for compiling and running Svelte at the edge on Cloudflare Workers.",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "check": "npm run css && tsc --noEmit",
    "bench:local": "tsx scripts/bench-local.ts",
    "report": "tsx scripts/experiment-report.ts",
    "build": "npm run css && wrangler deploy --dry-run --outdir dist",
    "bench:http": "tsx scripts/bench-http.ts",
    "bench:concurrent": "tsx scripts/bench-concurrent.ts",
    "css": "npm run og && tailwindcss -i ./src/input.css -o ./src/styles.css --minify && node scripts/generate-styles.mjs",
    "og": "node scripts/generate-og.mjs"
  },
  "dependencies": {
    "hono": "^4.12.18",
    "svelte": "latest"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "latest",
    "@tailwindcss/cli": "^4.3.0",
    "@types/node": "^25.7.0",
    "sharp-cli": "^5.2.0",
    "tailwindcss": "^4.3.0",
    "tsx": "latest",
    "typescript": "latest",
    "wrangler": "latest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/acoyfellow/svelte-edge.git"
  },
  "bugs": {
    "url": "https://github.com/acoyfellow/svelte-edge/issues"
  },
  "homepage": "https://svelte-edge.coey.dev",
  "keywords": "[\"svelte\",\"cloudflare-workers\",\"workers-ai\",\"edge\",\"agents\",\"hono\"]",
  "license": "MIT"
}
